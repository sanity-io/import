{
  "name": "@sanity/import",
  "version": "5.0.0",
  "description": "Import documents to a Sanity dataset",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "import",
    "ndjson"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/import/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/import.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/_exports/index.ts",
      "default": "./dist/_exports/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/_exports/index.js",
  "types": "./dist/_exports/index.d.ts",
  "files": [
    "dist",
    "oclif.manifest.json",
    "src"
  ],
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths && pnpm run build:types",
    "build:types": "pkg-utils build --emitDeclarationOnly",
    "coverage": "vitest run --coverage",
    "depcheck": "knip",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "watch": "swc src -d dist --strip-leading-paths --watch"
  },
  "dependencies": {
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/generate-help-url": "^4.0.0",
    "@sanity/mutator": "^5.14.1",
    "debug": "^4.4.3",
    "get-it": "^8.7.0",
    "get-uri": "^6.0.5",
    "gunzip-maybe": "^1.4.2",
    "lodash-es": "^4.17.23",
    "p-map": "^7.0.3",
    "split2": "^4.2.0",
    "tar-fs": "^2.1.4",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@sanity/client": "^7.17.0",
    "@sanity/eslint-config-cli": "^0.0.0-alpha.4",
    "@sanity/pkg-utils": "^10.4.8",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/debug": "^4.1.12",
    "@types/gunzip-maybe": "1.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.0",
    "@types/split2": "^4.2.3",
    "@types/tar-fs": "2.0.4",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^9.39.4",
    "knip": "^5.86.0",
    "nock": "^14.0.11",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^2.5.22",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@sanity/client": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20.19.1 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
